<Window x:Class="Net10.Wpf.Rest.IssueBoard.Views.IssueDeleteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Net10.Wpf.Rest.IssueBoard.Converters"
        Title="DeleteConfirmation" Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:IssueStatusConverter x:Key="StatusConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Are you sure you want to delete this issue?" 
                   FontSize="16" FontWeight="Bold" Foreground="Red" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="AuthorName" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="AuthorNameTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="CreatedAt" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="CreatedAtTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="Category" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="CategoryTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="Title" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="TitleTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="Description" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="DescriptionTextBox" IsReadOnly="True" Background="#F0F0F0" 
                         TextWrapping="Wrap" AcceptsReturn="True" 
                         Height="100" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="Status" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="StatusTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="Resolution" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="ResolutionTextBox" IsReadOnly="True" Background="#F0F0F0" 
                         TextWrapping="Wrap" AcceptsReturn="True" 
                         Height="100" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="ResolverName" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="ResolverNameTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="ResolvedAt" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="ResolvedAtTextBox" IsReadOnly="True" Background="#F0F0F0" Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Delete" Width="100" Height="30" Margin="5" Click="DeleteButton_Click" Background="#FFE57373"/>
            <Button Content="Back" Width="100" Height="30" Margin="5" Click="BackButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
