<Window x:Class="Net10.Wpf.Rest.IssueBoard.Views.IssueEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IssueEdit" Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="AuthorName (ReadOnly)" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="AuthorNameTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="CreatedAt (ReadOnly)" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="CreatedAtTextBox" IsReadOnly="True" Background="#F0F0F0"/>

                <TextBlock Text="Category" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="CategoryTextBox" MaxLength="30"/>

                <TextBlock Text="Title *" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="TitleTextBox" MaxLength="100"/>

                <TextBlock Text="Description *" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="DescriptionTextBox" TextWrapping="Wrap" AcceptsReturn="True" 
                         MaxLength="2000" Height="100" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="Status" FontWeight="Bold" Margin="0,10,0,5"/>
                <ComboBox x:Name="StatusComboBox" DisplayMemberPath="Display" SelectedValuePath="Value"/>

                <TextBlock Text="Resolution" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="ResolutionTextBox" TextWrapping="Wrap" AcceptsReturn="True" 
                         MaxLength="2000" Height="100" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="ResolverName" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="ResolverNameTextBox" MaxLength="50"/>

                <TextBlock Text="ResolvedAt (Auto)" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="ResolvedAtTextBox" IsReadOnly="True" Background="#F0F0F0" Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Update" Width="100" Height="30" Margin="5" Click="UpdateButton_Click"/>
            <Button Content="Back" Width="100" Height="30" Margin="5" Click="BackButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
