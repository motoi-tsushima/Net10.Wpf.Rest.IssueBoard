<Window x:Class="Net10.Wpf.Rest.IssueBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Net10.Wpf.Rest.IssueBoard"
        xmlns:converters="clr-namespace:Net10.Wpf.Rest.IssueBoard.Converters"
        mc:Ignorable="d"
        Title="Issue Board" Height="600" Width="1200"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:IssueStatusConverter x:Key="StatusConverter"/>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="IssuesDataGrid" Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="IssuesDataGrid_MouseDoubleClick"
                  CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="AuthorName" Binding="{Binding AuthorName}" Width="120"/>
                <DataGridTextColumn Header="CreatedAt" Binding="{Binding CreatedAt, StringFormat='yyyy/MM/dd HH:mm'}" Width="140"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status, Converter={StaticResource StatusConverter}}" Width="120"/>
                <DataGridTextColumn Header="ResolverName" Binding="{Binding ResolverName}" Width="120"/>
                <DataGridTextColumn Header="ResolvedAt" Binding="{Binding ResolvedAt, StringFormat='yyyy/MM/dd HH:mm'}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Create" Width="100" Height="30" Margin="5" Click="CreateButton_Click"/>
            <Button Content="Exit" Width="100" Height="30" Margin="5" Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
